{
  "name": "check-version-change",
  "version": "1.1.1",
  "private": true,
  "description": "GitHub Action that compares a local package version with a registry version or another Git ref.",
  "license": "MIT",
  "author": {
    "name": "José F. Ruiz",
    "url": "https://github.com/jfrz38"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jfrz38/check-version-change.git"
  },
  "bugs": {
    "url": "https://github.com/jfrz38/check-version-change/issues"
  },
  "homepage": "https://github.com/jfrz38/check-version-change#readme",
  "keywords": [
    "github-action",
    "github-actions",
    "version-check",
    "version-compare",
    "release",
    "semver",
    "npm",
    "pypi",
    "maven",
    "crates",
    "golang",
    "vscode"
  ],
  "main": "dist/index.js",
  "type": "commonjs",
  "packageManager": "pnpm@10.12.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node20 --format=cjs --minify --outfile=dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit",
    "test:watch": "vitest tests/unit",
    "test:coverage": "vitest run --coverage tests/unit",
    "test:smoke": "vitest run tests/smoke",
    "test:acceptance": "vitest run tests/acceptance-tests",
    "validate": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/github": "9.1.1",
    "semver": "7.7.4"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "esbuild": "0.28.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
